# Eira — environment variables
# Copy to .env for local dev, or set in Vercel Project Settings → Environment Variables.

# --- Database ---
# Local dev (SQLite file — auto-created on first run):
LIBSQL_URL=file:./data/eira.db
# (no LIBSQL_AUTH_TOKEN needed locally)

# Production (Turso — get these from https://turso.tech):
# LIBSQL_URL=libsql://eira-XXXXXX.turso.io
# LIBSQL_AUTH_TOKEN=eyJhbGciOi...

# --- Admin ---
# Password for the CMS at /admin.html — CHANGE THIS before deploy.
ADMIN_PASSWORD=changeme

# --- Site ---
# Used for absolute OG/Twitter URLs in SSR posts. Your real domain.
SITE_URL=https://eira.example

# --- Email (Resend — https://resend.com) ---
# Required to send welcome emails + newsletters. Without RESEND_API_KEY,
# signups are still stored but no email is sent.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Sender address. Must be on a domain you've verified in Resend for real sends.
# The default resend.dev sender only delivers to your own Resend account email.
# FROM_EMAIL=Eira <hello@yourdomain.com>
# Automatic welcome email on signup is OFF by default. Set to "true" to enable
# it (only takes effect once RESEND_API_KEY is also set).
# WELCOME_EMAIL_ENABLED=true
